generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FontProject {
  id         String      @id @default(cuid())
  name       String
  fileName   String
  fontData   Bytes
  createdAt  DateTime    @default(now())
  glyphPairs GlyphPair[]
}

model GlyphPair {
  id            String           @id @default(cuid())
  fontProjectId String
  fontProject   FontProject      @relation(fields: [fontProjectId], references: [id], onDelete: Cascade)
  leftGlyph     String
  rightGlyph    String
  baselineKern  Int              @default(0)
  currentMedian Float            @default(0)
  responseCount Int              @default(0)
  skipCount     Int              @default(0)
  adjustments   KernAdjustment[]

  @@unique([fontProjectId, leftGlyph, rightGlyph])
}

model KernAdjustment {
  id          String    @id @default(cuid())
  glyphPairId String
  glyphPair   GlyphPair @relation(fields: [glyphPairId], references: [id], onDelete: Cascade)
  sessionId   String
  value       Int
  createdAt   DateTime  @default(now())
}
